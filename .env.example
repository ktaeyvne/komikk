# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/manga_premium?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# Shinigami
SHINIGAMI_BASE_URL="https://g.shinigami.asia"

# Cloudinary (for image optimization)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Backend
BACKEND_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"

# Email (for auth - optional, use nodemailer)
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""

# Copy this to .env and fill values
# For production: Use Supabase/Neon for DB, Upstash for Redis

